@model Sportify.Models.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    var liveCount = Model.CanliMaclar.Count;
    var todayCount = Model.BugunMaclar.Count;
}

<!-- STAT CARDS -->
<div class="stat-grid">
    <div class="stat-card fade-in">
        <div class="stat-icon red">🔴</div>
        <div>
            <div class="stat-value" data-count="@liveCount">0</div>
            <div class="stat-label">Canlı Maç</div>
        </div>
    </div>
    <div class="stat-card fade-in">
        <div class="stat-icon blue">📅</div>
        <div>
            <div class="stat-value" data-count="@todayCount">0</div>
            <div class="stat-label">Bugünkü Maç</div>
        </div>
    </div>
</div>

<div class="dashboard-grid">
    <!-- LEFT COLUMN -->
    <div class="dashboard-col">

        <!-- LIVE MATCHES -->
        <div class="card">
            <div class="card-header">
                <div class="card-title">🔴 Canlı Maçlar <span class="live-badge">CANLI</span></div>
                <a href="#" onclick="pollLiveMatches(); return false;" class="section-link">↻ Yenile</a>
            </div>
            <div id="live-matches-container">
                @if (!Model.CanliMaclar.Any())
                {
                    <div class="empty-state">
                        <div class="empty-icon">🎽</div>
                        <p>Şu an canlı maç bulunmuyor</p>
                    </div>
                }
                else
                {
                    <div class="matches-grid">
                        @foreach (var m in Model.CanliMaclar)
                        {
                            <div class="match-card live fade-in">
                                <div class="match-league">
                                    @if (!string.IsNullOrEmpty(m.LigLogo))
                                    {
                                        <img src="@m.LigLogo" alt="" onerror="this.style.display='none'" />
                                    }
                                    @m.LigAdi
                                    <span class="match-status-badge live">🔴 CANLI</span>
                                </div>
                                <div class="match-teams">
                                    <div class="match-team">
                                        <img src="@m.EvSahibiLogo" alt="@m.EvSahibi" onerror="this.style.display='none'" />
                                        <div class="match-team-name">@m.EvSahibi</div>
                                    </div>
                                    <div class="match-score">
                                        <div class="score-num">@(m.EvSahibiSkor?.ToString() ?? "-")</div>
                                        <div class="score-sep">:</div>
                                        <div class="score-num">@(m.DeplasmanSkor?.ToString() ?? "-")</div>
                                    </div>
                                    <div class="match-team">
                                        <img src="@m.DeplasmanLogo" alt="@m.Deplasman" onerror="this.style.display='none'" />
                                        <div class="match-team-name">@m.Deplasman</div>
                                    </div>
                                </div>
                                @if (m.Dakika.HasValue)
                                {
                                    <div class="match-minute">⏱ @m.Dakika'</div>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

        <!-- TODAY'S MATCHES -->
        <div class="card">
            <div class="card-header">
                <div class="card-title">📅 Bugünkü Maçlar</div>
                <a href="#" onclick="pollTodayMatches(); return false;" class="section-link">↻ Yenile</a>
            </div>
            <div id="today-matches-container">
                @if (!Model.BugunMaclar.Any())
                {
                    <div class="empty-state">
                        <div class="empty-icon">📅</div>
                        <p>Bugün için maç bulunmuyor</p>
                    </div>
                }
                else
                {
                    <div class="matches-grid">
                        @foreach (var m in Model.BugunMaclar)
                        {
                            var isLive = m.Durum == "1H" || m.Durum == "2H" || m.Durum == "HT";
                            var isFT = m.Durum == "FT";
                            <div class="match-card @(isLive ? "live" : "") fade-in">
                                <div class="match-league">
                                    @if (!string.IsNullOrEmpty(m.LigLogo))
                                    {
                                        <img src="@m.LigLogo" alt="" onerror="this.style.display='none'" />
                                    }
                                    @m.LigAdi
                                    @if (isLive)
                                    {
                                        <span class="match-status-badge live">🔴 CANLI</span>
                                    }
                                    else if (isFT)
                                    {
                                        <span class="match-status-badge ft">Bitti</span>
                                    }
                                    else
                                    {
                                        <span class="match-status-badge ns">@m.Tarih.ToString("HH:mm")</span>
                                    }
                                </div>
                                <div class="match-teams">
                                    <div class="match-team">
                                        <img src="@m.EvSahibiLogo" alt="@m.EvSahibi" onerror="this.style.display='none'" />
                                        <div class="match-team-name">@m.EvSahibi</div>
                                    </div>
                                    <div class="match-score">
                                        @if (m.EvSahibiSkor.HasValue)
                                        {
                                            <div class="score-num">@m.EvSahibiSkor</div>
                                            <div class="score-sep">:</div>
                                            <div class="score-num">@m.DeplasmanSkor</div>
                                        }
                                        else
                                        {
                                            <div class="score-num" style="font-size:14px;color:var(--text-secondary)">vs</div>
                                        }
                                    </div>
                                    <div class="match-team">
                                        <img src="@m.DeplasmanLogo" alt="@m.Deplasman" onerror="this.style.display='none'" />
                                        <div class="match-team-name">@m.Deplasman</div>
                                    </div>
                                </div>
                                @if (m.Dakika.HasValue && isLive)
                                {
                                    <div class="match-minute">⏱ @m.Dakika'</div>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

    </div>

    <!-- RIGHT COLUMN -->
    <div class="dashboard-col">

        <!-- TOP 5 STANDINGS -->
        <div class="card">
            <div class="card-header">
                <div class="card-title">🏆 Puan Durumu</div>
                <a href="/Standings" class="section-link">Tümü →</a>
            </div>
            @foreach (var s in Model.UstSiraPuanDurumu)
            {
                <div class="mini-standing-row">
                    <div class="mini-rank @(s.Sira <= 4 ? "rank-cl" : s.Sira >= 18 ? "rank-rel" : "")">@s.Sira</div>
                    @if (!string.IsNullOrEmpty(s.TakimLogo))
                    {
                        <img class="mini-team-logo" src="@s.TakimLogo" alt="@s.TakimAdi" onerror="this.style.display='none'" />
                    }
                    <div class="mini-team-name">@s.TakimAdi</div>
                    <div class="mini-pts">@s.Puan</div>
                </div>
            }
            <a href="/Standings" class="section-link" style="display:block;text-align:center;margin-top:16px;">Tam Tabloyu Gör →</a>
        </div>

        <!-- TOP SCORERS -->
        <div class="card">
            <div class="card-header">
                <div class="card-title">⚡ Gol Krallığı</div>
                <a href="/Players" class="section-link">Tümü →</a>
            </div>
            @foreach (var p in Model.GolKralligi)
            {
                <div class="top-scorer-row">
                    @if (!string.IsNullOrEmpty(p.Foto))
                    {
                        <img class="top-scorer-photo" src="@p.Foto" alt="@p.Ad" onerror="this.style.display='none'" />
                    }
                    <div class="top-scorer-info">
                        <div class="top-scorer-name">@p.Ad</div>
                        <div class="top-scorer-team">@p.TakimAdi</div>
                    </div>
                    <div style="text-align:center">
                        <div class="top-scorer-goals">@(p.Istatistikler?.Goller ?? 0)</div>
                        <div class="top-scorer-goal-lbl">GOL</div>
                    </div>
                </div>
            }
            <a href="/Players" class="section-link" style="display:block;text-align:center;margin-top:16px;">Tüm Gol Krallığı →</a>
        </div>

    </div>
</div>
