@model List<Sportify.Models.Team>
@{
    ViewData["Title"] = "Takımlar";
}

<div class="section-title">🛡️ Takımlar</div>
<div class="section-subtitle">Premier League 2024/25 • Takım istatistikleri</div>

@if (!Model.Any())
{
    <div class="card">
        <div class="empty-state">
            <div class="empty-icon">🛡️</div>
            <p>Takım verisi bulunamadı</p>
        </div>
    </div>
}
else
{
    <div class="teams-grid">
        @foreach (var t in Model)
        {
            var s = t.Stats;
            <a href="/Teams/Detail/@t.Id" class="team-card fade-in">
                <div class="team-card-header">
                    <img class="team-card-logo" src="@t.Logo" alt="@t.Name" onerror="this.style.display='none'" />
                    <div>
                        <div class="team-card-name">@t.Name</div>
                        <div class="team-card-country">@t.Country @(t.Founded > 0 ? $"• {t.Founded}" : "")</div>
                        @if (!string.IsNullOrEmpty(t.Stadium))
                        {
                            <div style="font-size:12px;color:var(--text-muted);margin-top:3px;">🏟️ @t.Stadium</div>
                        }
                    </div>
                </div>
                @if (s != null)
                {
                    <div style="margin-bottom:12px;">
                        <div style="display:flex;justify-content:space-between;font-size:12px;color:var(--text-secondary);margin-bottom:4px;">
                            <span>Galibiyet Oranı</span>
                            <span style="font-weight:700;color:var(--win-green)">%@s.WinRate</span>
                        </div>
                        <div class="progress-bar">
                            <div class="progress-fill" style="width:@s.WinRate%;background:linear-gradient(90deg,var(--win-green),var(--accent3))"></div>
                        </div>
                    </div>
                    <div class="team-stats-row">
                        <div class="team-stat">
                            <div class="team-stat-val" style="color:var(--win-green)">@s.Won</div>
                            <div class="team-stat-lbl">Galibiyet</div>
                        </div>
                        <div class="team-stat">
                            <div class="team-stat-val" style="color:var(--draw-yellow)">@s.Drawn</div>
                            <div class="team-stat-lbl">Beraberlik</div>
                        </div>
                        <div class="team-stat">
                            <div class="team-stat-val" style="color:var(--loss-red)">@s.Lost</div>
                            <div class="team-stat-lbl">Mağlubiyet</div>
                        </div>
                        <div class="team-stat">
                            <div class="team-stat-val" style="color:var(--accent)">@s.Points</div>
                            <div class="team-stat-lbl">Puan</div>
                        </div>
                        <div class="team-stat">
                            <div class="team-stat-val">@s.GoalsFor</div>
                            <div class="team-stat-lbl">Gol</div>
                        </div>
                    </div>
                }
            </a>
        }
    </div>
}
