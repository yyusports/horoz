@model Sportify.Models.Player
@{
    ViewData["Title"] = Model.Name;
    var s = Model.Stats;
}

<div style="margin-bottom: 24px;">
    <a href="/Players" class="section-link">← Gol Krallığına Dön</a>
</div>

<div class="card" style="margin-bottom: 24px;">
    <div style="display:flex; align-items:center; gap: 28px; flex-wrap:wrap;">
        <img src="@Model.Photo" alt="@Model.Name" style="width:100px;height:100px;border-radius:50%;border:3px solid var(--border);object-fit:cover;background:var(--bg-secondary);" onerror="this.style.display='none'" />
        <div>
            <h2 style="font-size:26px;font-weight:900;margin-bottom:8px;">@Model.Name</h2>
            <div style="display:flex;flex-wrap:wrap;gap:12px;color:var(--text-secondary);font-size:14px;">
                <span>🌍 @Model.Nationality</span>
                <span>📅 @Model.Age yaşında</span>
                <span>🎽 @Model.Position</span>
                @if (!string.IsNullOrEmpty(Model.TeamName))
                {
                    <span>
                        @if (!string.IsNullOrEmpty(Model.TeamLogo))
                        {
                            <img src="@Model.TeamLogo" alt="" style="width:16px;height:16px;vertical-align:middle;object-fit:contain" onerror="this.style.display='none'" />
                        }
                        @Model.TeamName
                    </span>
                }
                @if (s?.Rating > 0)
                {
                    <span style="color:var(--win-green);font-weight:700">⭐ Puan: @s.Rating.ToString("F2")</span>
                }
            </div>
        </div>
    </div>
</div>

@if (s != null)
{
    <div class="section-title" style="font-size:18px;margin-bottom:16px;">📊 Sezon İstatistikleri</div>
    <div class="detail-grid">
        <div class="detail-stat fade-in">
            <div class="detail-stat-val">@s.Goals</div>
            <div class="detail-stat-lbl">Gol</div>
        </div>
        <div class="detail-stat fade-in">
            <div class="detail-stat-val">@s.Assists</div>
            <div class="detail-stat-lbl">Asist</div>
        </div>
        <div class="detail-stat fade-in">
            <div class="detail-stat-val">@s.Appearances</div>
            <div class="detail-stat-lbl">Maç</div>
        </div>
        <div class="detail-stat fade-in">
            <div class="detail-stat-val">@s.MinutesPlayed'</div>
            <div class="detail-stat-lbl">Dakika</div>
        </div>
        <div class="detail-stat fade-in">
            <div class="detail-stat-val">@s.Shots</div>
            <div class="detail-stat-lbl">Şut</div>
        </div>
        <div class="detail-stat fade-in">
            <div class="detail-stat-val">@s.ShotsOnTarget</div>
            <div class="detail-stat-lbl">İsabetli Şut</div>
        </div>
        <div class="detail-stat fade-in">
            <div class="detail-stat-val">@s.Passes</div>
            <div class="detail-stat-lbl">Pas</div>
        </div>
        <div class="detail-stat fade-in">
            <div class="detail-stat-val">%@s.PassAccuracy</div>
            <div class="detail-stat-lbl">Pas İsabeti</div>
        </div>
        <div class="detail-stat fade-in">
            <div class="detail-stat-val" style="color:var(--draw-yellow)">@s.YellowCards</div>
            <div class="detail-stat-lbl">Sarı Kart</div>
        </div>
        <div class="detail-stat fade-in">
            <div class="detail-stat-val" style="color:var(--loss-red)">@s.RedCards</div>
            <div class="detail-stat-lbl">Kırmızı Kart</div>
        </div>
    </div>

    @if (s.Shots > 0)
    {
        <div class="card" style="margin-top:24px;">
            <div class="card-title" style="margin-bottom:16px;">📈 Etkinlik</div>
            <div style="margin-bottom:12px;">
                <div style="display:flex;justify-content:space-between;font-size:13px;margin-bottom:4px;">
                    <span>İsabetli Şut Oranı</span>
                    <span style="font-weight:700">@(s.Shots > 0 ? (int)((double)s.ShotsOnTarget / s.Shots * 100) : 0)%</span>
                </div>
                <div class="progress-bar">
                    <div class="progress-fill" style="width:@(s.Shots > 0 ? (int)((double)s.ShotsOnTarget / s.Shots * 100) : 0)%"></div>
                </div>
            </div>
            <div style="margin-bottom:12px;">
                <div style="display:flex;justify-content:space-between;font-size:13px;margin-bottom:4px;">
                    <span>Gol Dönüşüm Oranı</span>
                    <span style="font-weight:700">@(s.Shots > 0 ? (int)((double)s.Goals / s.Shots * 100) : 0)%</span>
                </div>
                <div class="progress-bar">
                    <div class="progress-fill" style="width:@(s.Shots > 0 ? (int)((double)s.Goals / s.Shots * 100) : 0)%;background:linear-gradient(90deg, var(--win-green), var(--accent3))"></div>
                </div>
            </div>
        </div>
    }
}
