@model Sportify.Models.Kullanici

@{
    ViewData["Title"] = Model.KullaniciAdi + " Profili";
}

<div class="fade-in">
    <div class="section-header" style="margin-bottom: 32px;">
        <h2 class="section-title">Kullanıcı Profili</h2>
        <p class="section-subtitle">Hesap bilgilerini buradan yönetebilirsin.</p>
    </div>

    @if (TempData["Mesaj"] != null)
    {
        <div class="auth-alert-error" style="color: var(--win-green); border-color: rgba(16, 185, 129, 0.2); background: rgba(16, 185, 129, 0.1); padding: 12px; border-radius: 10px; margin-bottom: 20px;">
            ✅ @TempData["Mesaj"]
        </div>
    }
    @if (TempData["Hata"] != null)
    {
        <div class="auth-alert-error" style="padding: 12px; border-radius: 10px; margin-bottom: 20px;">
            ❌ @TempData["Hata"]
        </div>
    }

    <div class="card" style="max-width: 800px; margin: 0 auto; position: relative; overflow: visible; padding: 0; background: var(--bg-card); border-radius: 16px;">
        <!-- Profil Header -->
        <div style="background: var(--bg-secondary); height: 120px; position: relative; border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: center; overflow: hidden; border-radius: 16px 16px 0 0;">
            <div style="font-family: 'Inter', sans-serif; font-weight: 100; font-size: 48px; color: rgba(255, 255, 255, 0.15); letter-spacing: 20px; pointer-events: none; text-transform: uppercase; user-select: none; position: absolute; white-space: nowrap; font-style: italic;">
                SPORTİFY
            </div>
        </div>

        <!-- Profil Fotoğrafı (Header'ın dışına taşması için absolute ve doğru konumda) -->
        <div style="position: absolute; top: 70px; left: 40px; width: 110px; height: 110px; background: var(--bg-card); border-radius: 24px; border: 4px solid var(--border); display: flex; align-items: center; justify-content: center; font-size: 52px; box-shadow: 0 15px 35px rgba(0,0,0,0.4); overflow: hidden; z-index: 10;">
            @if (!string.IsNullOrEmpty(Model.ProfilResmiYolu))
            {
                <img src="@Model.ProfilResmiYolu" style="width: 100%; height: 100%; object-fit: cover;" />
            }
            else
            {
                <span>👤</span>
            }
        </div>

        <!-- Profil Detayları -->
        <div style="padding: 70px 40px 40px;">
            <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 32px;">
                <div>
                    <h1 style="font-size: 32px; font-weight: 800; margin-bottom: 4px; color: var(--text-primary);">@Model.KullaniciAdi</h1>
                    <p style="color: var(--text-secondary); font-size: 15px;">Sportify Üyesi</p>
                </div>
                <div>
                    @if (User.Identity?.Name == Model.KullaniciAdi)
                    {
                        <form asp-action="UploadProfilePhoto" method="post" enctype="multipart/form-data" id="photoForm">
                            <input type="file" name="profilResmi" id="profilResmi" style="display: none;" onchange="document.getElementById('photoForm').submit();" accept="image/*" />
                            <button type="button" onclick="document.getElementById('profilResmi').click();" class="auth-btn" style="margin: 0; padding: 6px 14px; font-size: 12px; transform: none !important; transition: none !important; animation: none !important; box-shadow: none !important;">
                                📷 Fotoğrafı Değiştir
                            </button>
                        </form>
                    }
                    else
                    {
                        <div class="rating-badge" style="font-size: 14px;">✨ Aktif Kullanıcı</div>
                    }
                </div>
            </div>

            <div class="stat-grid" style="grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));">
                <div class="stat-card">
                    <div class="stat-icon blue">📧</div>
                    <div>
                        <div class="stat-label">E-posta Adresi</div>
                        <div class="stat-value" style="font-size: 18px;">@Model.Email</div>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon purple">📅</div>
                    <div>
                        <div class="stat-label">Üyelik Tarihi</div>
                        <div class="stat-value" style="font-size: 18px;">@Model.OlusturmaTarihi.ToString("dd MMMM yyyy")</div>
                    </div>
                </div>
            </div>

            <div style="margin-top: 40px; padding-top: 32px; border-top: 1px solid var(--border);">
                @{
                    var favoriteTeams = ViewBag.FavoriteTeams as List<Sportify.Models.Takim>;
                }
                <h3 style="font-size: 18px; font-weight: 700; margin-bottom: 20px; display: flex; align-items: center; gap: 8px;">
                    ⭐ Favori Takımlar
                </h3>
                
                @if (favoriteTeams != null && favoriteTeams.Any())
                {
                    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 16px;">
                        @foreach (var team in favoriteTeams)
                        {
                            <a href="/Teams/Detail/@team.Id" style="text-decoration: none; display: flex; align-items: center; gap: 12px; background: var(--bg-secondary); padding: 12px; border-radius: 12px; border: 1px solid var(--border); transition: all 0.2s ease;" onmouseover="this.style.borderColor='var(--accent)'; this.style.transform='translateY(-2px)';" onmouseout="this.style.borderColor='var(--border)'; this.style.transform='translateY(0)';" class="fade-in">
                                <img src="@team.Logo" alt="@team.Ad" style="width: 32px; height: 32px; object-fit: contain; background: rgba(255, 255, 255, 0.05); border-radius: 6px; padding: 4px;" />
                                <span style="font-size: 14px; font-weight: 600; color: var(--text-primary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">@team.Ad</span>
                            </a>
                        }
                    </div>
                }
                else
                {
                    <div style="background: rgba(255, 255, 255, 0.02); border: 1px dashed var(--border); border-radius: 12px; padding: 30px; text-align: center;">
                        <div style="font-size: 32px; margin-bottom: 12px; opacity: 0.5;">🛡️</div>
                        <p style="color: var(--text-secondary); font-size: 14px;">Henüz bir favori takım belirlemedin.</p>
                        <a href="/Teams" style="color: var(--accent); font-size: 13px; text-decoration: none; margin-top: 8px; display: inline-block; font-weight: 600;">Takımları Keşfet →</a>
                    </div>
                }
            </div>

            <div style="margin-top: 40px; padding-top: 32px; border-top: 1px solid var(--border);">
                <h3 style="font-size: 18px; font-weight: 700; margin-bottom: 16px;">Hesap Durumu</h3>
                <div style="display: flex; gap: 12px; flex-wrap: wrap;">
                    <div style="background: rgba(16, 185, 129, 0.1); color: var(--win-green); padding: 8px 16px; border-radius: 10px; font-size: 13px; font-weight: 600; border: 1px solid rgba(16, 185, 129, 0.2);">
                        ✓ E-posta Doğrulandı
                    </div>
                    @if (User.Identity?.Name == Model.KullaniciAdi)
                    {
                        <div style="background: rgba(0, 212, 255, 0.1); color: var(--accent); padding: 8px 16px; border-radius: 10px; font-size: 13px; font-weight: 600; border: 1px solid rgba(0, 212, 255, 0.2);">
                            ⚙️ Kendi Profilin
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Profil sayfasına özel CSS eklemeleri buraya gelebilir */
</style>
