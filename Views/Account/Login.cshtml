@model Sportify.Models.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Giriş Yap";
}

<div class="auth-wrapper">
    <div class="auth-card fade-in">
        <div class="auth-header">
            <div class="auth-logo">⚽</div>
            <h2 class="auth-title">Giriş Yap</h2>
            <p class="auth-subtitle">Sportify hesabına giriş yap</p>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="auth-alert-error">
                @foreach (var hata in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div>❌ @hata.ErrorMessage</div>
                }
            </div>
        }

        <form asp-action="Login" asp-route-returnUrl="@ViewBag.ReturnUrl" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="All" class="auth-alert-error"></div>
            <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

            <div class="form-group">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-input" placeholder="ornek@email.com" autocomplete="email" />
                <span asp-validation-for="Email" class="form-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Sifre" class="form-label"></label>
                <input asp-for="Sifre" class="form-input" placeholder="Şifreniz" autocomplete="current-password" />
                <span asp-validation-for="Sifre" class="form-error"></span>
            </div>

            <div class="form-check">
                <input asp-for="BeniHatirla" type="checkbox" class="form-checkbox" id="beniHatirla" />
                <label for="beniHatirla" class="form-check-label">Beni Hatırla</label>
            </div>

            <button type="submit" class="auth-btn">Giriş Yap</button>
        </form>

        <p class="auth-footer">
            Hesabın yok mu?
            <a asp-controller="Account" asp-action="Register" class="auth-link">Kayıt Ol</a>
        </p>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
